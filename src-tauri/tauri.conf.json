{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Excel 脏数据清洗工具",
    "version": "0.1.0",
    "identifier": "com.xxy.cleaningapp",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Excel 脏数据清洗工具",
                "minWidth": 1300,
                "height": 1000
            }
        ],
        "macOSPrivateApi": true,
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "macOS": {
            "entitlements": null,
            "exceptionDomain": "",
            "frameworks": null,
            "providerShortName": null,
            "signingIdentity": null
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
